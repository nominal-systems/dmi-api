{
  "name": "diagnostic-modality-integration-api",
  "version": "1.14.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "rimraf dist",
    "clean": "rm -rf dist",
    "docker:build": "docker build -t nominal-systems/dmi-api . --build-arg GHP_TOKEN=$GHP_TOKEN",
    "postdocker:build": "docker tag nominal-systems/dmi-api:latest nominal-systems/dmi-api:$npm_package_version",
    "build": "nest build",
    "preversion": "npm run lint",
    "version": "git add -A src",
    "postversion": "git push --follow-tags",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "ensure-integration-status": "node dist/ensure-integration-status",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "typeorm": "ts-node --transpile-only ./node_modules/typeorm/cli.js -d src/config/data-source.ts",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:create": "ts-node --transpile-only ./node_modules/typeorm/cli.js migration:create",
    "migration:generate": "npm run typeorm -- migration:generate",
    "migration:revert": "npm run typeorm -- migration:revert",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "migrate:mongo-shards": "node scripts/mongo-shard-migrate.js --collections=events,external_requests,internal_events --suffix=_v2 --batch=1000",
    "seed": "NODE_ENV=seed ts-node -r tsconfig-paths/register src/seeder.ts",
    "generate-session-key": "npx @fastify/secure-session > .secret-key"
  },
  "dependencies": {
    "@azure/core-auth": "^1.4.0",
    "@azure/event-hubs": "^5.8.0",
    "@fastify/cookie": "^9.4.0",
    "@fastify/passport": "^2.5.0",
    "@fastify/session": "^10.9.0",
    "@fastify/static": "^6.12.0",
    "@nestjs/common": "^10.3.2",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.2",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "^2.0.5",
    "@nestjs/microservices": "^10.3.2",
    "@nestjs/mongoose": "^10.1.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.2",
    "@nestjs/platform-fastify": "^10.3.2",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/terminus": "^10.2.3",
    "@nestjs/typeorm": "^10.0.2",
    "@nominal-systems/dmi-engine-common": "^1.4.0",
    "argon2": "^0.28.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "faker": "^5.5.3",
    "fastify": "^4.28.1",
    "is-my-json-valid": "^2.20.5",
    "jwks-rsa": "^2.0.5",
    "moment": "^2.30.1",
    "mongoose": "^6.13.9",
    "mongoose-sequence": "^6.0.1",
    "mqtt": "^4.2.8",
    "mysql2": "^2.2.5",
    "nanoid": "^3.1.23",
    "nanoid-dictionary": "^4.3.0",
    "nest-winston": "^1.9.4",
    "passport": "^0.6.0",
    "passport-http": "^0.3.0",
    "passport-jwt": "^4.0.0",
    "passport-openidconnect": "^0.1.2",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^5.0.5",
    "rxjs": "^7.8.1",
    "statsig-node": "^6.5.1",
    "typeorm": "^0.3.20",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.1",
    "@nestjs/testing": "^10.3.2",
    "@types/express": "^4.17.21",
    "@types/faker": "^5.5.7",
    "@types/jest": "^29.5.12",
    "@types/nanoid-dictionary": "^4.2.0",
    "@types/node": "^20.5.9",
    "@types/passport": "^1.0.17",
    "@types/passport-http": "^0.3.9",
    "@types/passport-jwt": "^3.0.6",
    "@types/passport-openidconnect": "^0.1.3",
    "@types/supertest": "^2.0.11",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.44.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.5",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.1.1",
    "jest": "^29.7.0",
    "prettier": "^2.3.2",
    "sqlite3": "^5.1.1",
    "supertest": "^6.1.4",
    "ts-jest": "^29.3.2",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3",
    "version": "^0.1.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
